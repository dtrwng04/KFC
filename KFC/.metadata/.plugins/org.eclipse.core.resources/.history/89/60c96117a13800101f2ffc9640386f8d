<!-- Modal Thêm Đặt Bàn -->
<div class="modal fade" id="addReservationModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-kfc-red text-white">
        <h5 class="modal-title">Thêm Đặt Bàn Mới</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="addReservationForm">
          <div class="row mb-3">
            <div class="col-md-6">
              <label for="newCustomerName" class="form-label">Tên khách hàng <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="newCustomerName" required>
            </div>
            <div class="col-md-6">
              <label for="newCustomerPhone" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
              <input type="tel" class="form-control" id="newCustomerPhone" required>
            </div>
          </div>
          
          <div class="row mb-3">
            <div class="col-md-4">
              <label for="newReservationDate" class="form-label">Ngày <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="newReservationDate" required>
            </div>
            <div class="col-md-4">
              <label for="newReservationTime" class="form-label">Giờ <span class="text-danger">*</span></label>
              <input type="time" class="form-control" id="newReservationTime" required>
            </div>
            <div class="col-md-4">
              <label for="newPartySize" class="form-label">Số người <span class="text-danger">*</span></label>
              <select class="form-select" id="newPartySize" required>
                <option value="" selected disabled>Chọn...</option>
                <option value="1">1 người</option>
                <option value="2">2 người</option>
                <option value="4">3-4 người</option>
                <option value="6">5-6 người</option>
                <option value="8">7-8 người</option>
                <option value="10">Trên 8 người</option>
              </select>
            </div>
          </div>
          
          <div class="mb-3">
            <label for="newTableNumber" class="form-label">Bàn <span class="text-danger">*</span></label>
            <select class="form-select" id="newTableNumber" required>
              <option value="" selected disabled>Chọn bàn...</option>
              <option value="1">Bàn 1 (2-4 người)</option>
              <option value="2">Bàn 2 (4-6 người)</option>
              <option value="3">Bàn 3 (6-8 người)</option>
            </select>
          </div>
          
          <div class="mb-3">
            <label for="newSpecialRequests" class="form-label">Yêu cầu đặc biệt</label>
            <textarea class="form-control" id="newSpecialRequests" rows="3"></textarea>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        <button type="button" class="btn btn-primary" onclick="addReservation()">Thêm Đặt Bàn</button>
      </div>
    </div>
  </div>
</div>

