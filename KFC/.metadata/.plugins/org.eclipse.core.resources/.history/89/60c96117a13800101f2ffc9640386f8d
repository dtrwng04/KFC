                <option value="2">2 người</option>
                <option value="4">3-4 người</option>
                <option value="6">5-6 người</option>
                <option value="8">7-8 người</option>
                <option value="10">Trên 8 người</option>
              </select>
            </div>
          </div>
          
          <div class="mb-3">
            <label for="editTableNumber" class="form-label">Bàn <span class="text-danger">*</span></label>
            <select class="form-select" id="editTableNumber" required>
              <option value="" selected disabled>Chọn bàn...</option>
              <option value="1">Bàn 1 (2-4 người)</option>
              <option value="2">Bàn 2 (4-6 người)</option>
              <option value="3">Bàn 3 (6-8 người)</option>
            </select>
          </div>
          
          <div class="mb-3">
            <label for="editSpecialRequests" class="form-label">Yêu cầu đặc biệt</label>
            <textarea class="form-control" id="editSpecialRequests" rows="3"></textarea>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        <button type="button" class="btn btn-primary" onclick="updateReservation()">Cập Nhật</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Xác Nhận Xóa -->
<div class="modal fade" id="deleteConfirmationModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">Xác Nhận Xóa</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Bạn có chắc chắn muốn xóa đặt bàn <strong id="reservationToDelete"></strong> không?</p>
        <p class="text-danger">Hành động này không thể hoàn tác!</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" class="btn btn-danger" onclick="confirmDelete()">Xóa</button>
      </div>
    </div>
  </div>
</div>

<!-- Vendor JS Files -->
<script src="assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="assets/vendor/simple-datatables/simple-datatables.js"></script>

<!-- Template Main JS File -->
<script src="assets/js/main.js"></script>

<!-- Custom JS for Reservation Management -->
<script>
  // Dữ liệu mẫu - Thay bằng API thực tế
  let reservations = [
    {
      id: "KFC-001",
      customerName: "Nguyễn Văn An",
      phone: "0912345678",
      table: "Bàn 2",
      tableId: "2",
      date: "2025-05-17",
      time: "18:00",
      people: "4",
      status: "pending",
      specialRequests: ""
    },
    {
      id: "KFC-002",
      customerName: "Trần Thị Bình",
      phone: "0987654321",
      table: "Bàn 5",
      tableId: "5",
      date: "2025-05-17",
      time: "19:30",
      people: "2",
      status: "confirmed",
      specialRequests: "Yêu cầu chỗ ngồi gần cửa sổ"
    },
    {
      id: "KFC-003",
      customerName: "Lê Văn Cường",
      phone: "0905123456",
      table: "Bàn 3",
      tableId: "3",
      date: "2025-05-17",
      time: "12:00",
      people: "6",
      status: "completed",
      specialRequests: ""
    },
    {
      id: "KFC-004",
      customerName: "Phạm Thị Dung",
      phone: "0978123456",
      table: "Bàn 1",
      tableId: "1",
      date: "2025-05-17",
      time: "11:30",
      people: "3",
      status: "cancelled",
      specialRequests: ""
    }
  ];

  // Khởi tạo khi trang được tải
  document.addEventListener('DOMContentLoaded', function() {
    // Set today's date as default
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('filterDate').value = today;
    document.getElementById('newReservationDate').value = today;
    document.getElementById('editReservationDate').value = today;
    
    // Load initial data
    refreshReservationsTable();
  });

  // Hàm làm mới bảng đặt bàn
  function refreshReservationsTable() {
    const tableBody = document.querySelector('#reservationsTable tbody');
    tableBody.innerHTML = '';
    
    // Lấy giá trị filter
    const filterDate = document.getElementById('filterDate').value;
    const filterStatus = document.getElementById('filterStatus').value;
    const filterTable = document.getElementById('filterTable').value;
    
    // Lọc dữ liệu
    const filteredReservations = reservations.filter(reservation => {
      const matchesDate = filterDate ? reservation.date === filterDate : true;
      const matchesStatus = filterStatus !== 'all' ? reservation.status === filterStatus : true;
      const matchesTable = filterTable !== 'all' ? reservation.tableId === filterTable : true;
      return matchesDate && matchesStatus && matchesTable;
    });
    
    // Đếm số lượng đặt bàn hôm nay
    const todayReservations = reservations.filter(r => r.date === new Date().toISOString().split('T')[0]);
    document.querySelector('.card-title .badge').textContent = `Hôm nay: ${todayReservations.length}`;
    
    // Thêm dữ liệu vào bảng
    filteredReservations.forEach(reservation => {
      const statusClass = getStatusClass(reservation.status);
      const statusText = getStatusText(reservation.status);
      const statusBadgeClass = getStatusBadgeClass(reservation.status);
      
      const row = document.createElement('tr');
      row.className = `reservation-card ${statusClass}`;
      row.innerHTML = `
        <td>#${reservation.id}</td>
        <td>${reservation.customerName}</td>
        <td>${reservation.phone}</td>
        <td>${reservation.table}</td>
        <td>${reservation.time} - ${formatDate(reservation.date)}</td>
        <td>${reservation.people}</td>
        <td><span class="status-badge ${statusBadgeClass}">${statusText}</span></td>
        <td>
          <div class="action-buttons">
            <button class="btn btn-sm btn-primary me-1 edit-btn" title="Sửa" data-id="${reservation.id}">
              <i class="bi bi-pencil"></i>
            </button>
            <button class="btn btn-sm btn-danger delete-btn" title="Xóa" data-id="${reservation.id}">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </td>
      `;
      tableBody.appendChild(row);
    });
    
    // Thêm sự kiện cho các nút edit và delete
    addEditDeleteEventListeners();
  }

  // Hàm lọc đặt bàn
  function filterReservations() {
    refreshReservationsTable();
  }

  // Hàm thêm đặt bàn mới
  function addReservation() {
    const newReservation = {
      id: "KFC-" + Math.floor(1000 + Math.random() * 9000),
      customerName: document.getElementById('newCustomerName').value,
      phone: document.getElementById('newCustomerPhone').value,
      table: document.getElementById('newTableNumber').options[document.getElementById('newTableNumber').selectedIndex].text,
      tableId: document.getElementById('newTableNumber').value,
      date: document.getElementById('newReservationDate').value,
      time: document.getElementById('newReservationTime').value,
      people: document.getElementById('newPartySize').value,
      status: "pending",
      specialRequests: document.getElementById('newSpecialRequests').value
    };
    
    // Thêm vào mảng reservations (thay bằng API POST trong thực tế)
    reservations.push(newReservation);
    
    // Làm mới bảng và đóng modal
    refreshReservationsTable();
    bootstrap.Modal.getInstance(document.getElementById('addReservationModal')).hide();
    
    // Hiển thị thông báo và reset form
    alert('Thêm đặt bàn thành công!');
    document.getElementById('addReservationForm').reset();
  }

  // Hàm mở modal sửa
  function addEditDeleteEventListeners() {
    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const reservationId = this.getAttribute('data-id');
        const reservation = reservations.find(r => r.id === reservationId);
        
        if (reservation) {
          document.getElementById('editReservationId').value = reservation.id;
          document.getElementById('editCustomerName').value = reservation.customerName;
          document.getElementById('editCustomerPhone').value = reservation.phone;
          document.getElementById('editReservationDate').value = reservation.date;
          document.getElementById('editReservationTime').value = reservation.time;
          document.getElementById('editPartySize').value = reservation.people;
          document.getElementById('editSpecialRequests').value = reservation.specialRequests || '';
          
          // Chọn bàn tương ứng
          const tableSelect = document.getElementById('editTableNumber');
          for (let i = 0; i < tableSelect.options.length; i++) {
            if (tableSelect.options[i].value === reservation.tableId) {
              tableSelect.selectedIndex = i;
              break;
            }
          }
          
          // Mở modal
          new bootstrap.Modal(document.getElementById('editReservationModal')).show();
        }
      });
    });
    
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const reservationId = this.getAttribute('data-id');
        document.getElementById('reservationToDelete').textContent = '#' + reservationId;
        
        // Lưu reservationId vào modal để sử dụng khi xác nhận
        document.getElementById('deleteConfirmationModal').setAttribute('data-reservation-id', reservationId);
        
        // Mở modal
        new bootstrap.Modal(document.getElementById('deleteConfirmationModal')).show();
      });
    });
  }

  // Hàm cập nhật đặt bàn
  function updateReservation() {
    const reservationId = document.getElementById('editReservationId').value;
    const reservationIndex = reservations.findIndex(r => r.id === reservationId);
    
    if (reservationIndex !== -1) {
      reservations[reservationIndex] = {
        ...reservations[reservationIndex],
        customerName: document.getElementById('editCustomerName').value,
        phone: document.getElementById('editCustomerPhone').value,
        table: document.getElementById('editTableNumber').options[document.getElementById('editTableNumber').selectedIndex].text,
        tableId: document.getElementById('editTableNumber').value,
        date: document.getElementById('editReservationDate').value,
        time: document.getElementById('editReservationTime').value,
        people: document.getElementById('editPartySize').value,
        specialRequests: document.getElementById('editSpecialRequests').value
      };
      
      // Làm mới bảng và đóng modal
      refreshReservationsTable();
      bootstrap.Modal.getInstance(document.getElementById('editReservationModal')).hide();
      
      // Hiển thị thông báo
      alert('Cập nhật đặt bàn thành công!');
    }
  }

  // Hàm xóa đặt bàn
  function confirmDelete() {
    const reservationId = document.getElementById('deleteConfirmationModal').getAttribute('data-reservation-id');
    
    // Xóa khỏi mảng reservations (thay bằng API DELETE trong thực tế)
    reservations = reservations.filter(r => r.id !== reservationId);
    
    // Làm mới bảng và đóng modal
    refreshReservationsTable();
    bootstrap.Modal.getInstance(document.getElementById('deleteConfirmationModal')).hide();
    
    // Hiển thị thông báo
    alert('Đã xóa đặt bàn thành công!');
  }

  // Các hàm hỗ trợ
  function getStatusClass(status) {
    switch(status) {
      case 'pending': return 'reservation-pending';
      case 'confirmed': return 'reservation-confirmed';
      case 'completed': return 'reservation-completed';
      case 'cancelled': return 'reservation-cancelled';
      default: return '';
    }
  }

  function getStatusBadgeClass(status) {
    switch(status) {
      case 'pending': return 'bg-warning';
      case 'confirmed': return 'bg-success';
      case 'completed': return 'bg-info';
      case 'cancelled': return 'bg-danger';
      default: return '';
    }
  }

  function getStatusText(status) {
    switch(status) {
      case 'pending': return 'Chờ xác nhận';
      case 'confirmed': return 'Đã xác nhận';
      case 'completed': return 'Hoàn thành';
      case 'cancelled': return 'Đã hủy';
      default: return '';
    }
  }

  function formatDate(dateString) {
    const date = new Date(dateString);
    return date.toLocaleDateString('vi-VN');
  }
</script>

</body>

</html>